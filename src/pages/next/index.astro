---
import NextLayout from '../../layouts/NextLayout.astro'
---
<NextLayout title="Next Generation | AstralSeal">
<body class="index-page">

  <header id="header" class="header d-flex align-items-center fixed-top">
    <div class="container-fluid position-relative d-flex align-items-center justify-content-between">
      <a href="../../" class="logo d-flex align-items-center me-auto me-xl-0">
        <h1 class="sitename">AstralSeal</h1>
      </a>
      <nav id="navmenu" class="navmenu">
        <ul>
          <li><a href="#" class="active">Home</a></li>
          <li><a href="#story">Story</a></li>
          <li><a href="#character">Character</a></li>
          <li><a href="/next/th">ภาษาไทย</a></li>
        </ul>
        <i class="mobile-nav-toggle d-xl-none bi bi-list"></i>
      </nav>
    </div>
  </header>

  <main class="main">
    <!-- Hero Section -->
    <section id="home" class="hero section">
      <img src="/images/next/next1.png" alt="Next Generation cover">
      <div class="container">
        <div class="row">
          <div class="col-lg-10">
            <h2 data-aos="fade-up" data-aos-delay="100">Next Generation</h2>
            <p data-aos="fade-up" data-aos-delay="200">The journey of the new generation of brave ones begins...</p>
          </div>
          <div class="col-lg-5 gy-4">
            <span class="btn btn-lg btn-secondary" data-aos="fade-up" data-aos-delay="300">Coming Soon</span>
          </div>
        </div>
      </div>
    </section><!-- /Hero Section -->

    <!-- Story Section -->
    <section id="story" class="services section">
      <div class="container section-title" data-aos="fade-up">
        <h2>Story</h2>
      </div>
      <div class="container">
        <div class="row gy-4">
          <div class="col-10 col-xl-8 mx-auto text-center mainstory" data-aos="fade-up" data-aos-delay="100">
            <p>ในโลกที่ทุกอย่างตกลงสู่ความมืดจอมมารผู้ชั่วร้ายกลืนกินจิตวิญญาณและความหวังของผู้คน</p><br />
            <p>เมื่อแสงแห่งความหวังริบหรี่ “เหล่าผู้กล้า” ถูกอัญเชิญมาอีกครั้ง</p><br />
            <p>ซิลเวีย หญิงสาวผู้ถือครองดาบศักดิ์สิทธิ์ในตำนาน ผู้มีชะตาแบกรับความหวังของโลก</p>
            <p>ลูเซีย แม่ชีผู้เปี่ยมไปด้วยพลังชำระล้างผู้สามารถขับไล่ความมืดได้</p>
            <p>และ เรย์ นักสู้สาวผู้แข็งแกร่ง ผู้เชื่อมั่นในพลังของตนเองมากกว่าสิ่งใด</p><br />
            <p>ทั้งสามออกเดินทางสู่ดินแดนแห่งปีศาจ ที่ซึ่งกฎของความจริงถูกบิดเบือน </p><br/>
            <p><b>Next Generatio</b><br\></p>
              การเดินทางของเหล่าผู้กล้ายุคใหม่จึงได้เริ่มต้นขึ้น…</p>
          </div>
        </div>
      </div>
    </section><!-- /Story Section -->

    <!-- Character Section -->
    <section id="character" class="services section">
      <div class="container section-title" data-aos="fade-up">
        <h2>Character</h2>
      </div>
      <div class="container" data-aos="fade-up" data-aos-delay="100">
        <div class="row gy-4">
          <!-- Swiper -->
          <div class="swiper init-swiper mySwiper">
            <div class="swiper-wrapper">
              <div class="swiper-slide">
                <img src="/images/next/chara_yusha.png" alt="Sylvia" data-aos="fade-in">
              </div>
              <div class="swiper-slide">
                <img src="/images/next/chara_sister.png" alt="Lucia" data-aos="fade-in">
              </div>
              <div class="swiper-slide">
                <img src="/images/next/chara_berserk.png" alt="Ray" data-aos="fade-in">
              </div>
              <div class="swiper-slide">
                <img src="/images/next/chara_vira.png" alt="Vira" data-aos="fade-in">
              </div>
            </div>
            <div class="swiper-button-next"></div>
            <div class="swiper-button-prev"></div>
          </div>
        </div>
      </div>
    </section><!-- /Character Section -->

    <!-- Call To Action Section -->
    <section id="call-to-action" class="call-to-action section">
      <img src="/images/next/next2.png" alt="">
      <div class="container">
        <div class="row justify-content-center" data-aos="zoom-in" data-aos-delay="100">
          <div class="col-xl-10">
            <div class="text-center">
              <h3>Next Generation</h3>
              <p>Coming Soon — Stay tuned for updates!</p>
              <a class="cta-btn" href="https://www.facebook.com/AstralSeal2023" target="_blank" rel="noopener noreferrer">Follow Us</a>
            </div>
          </div>
        </div>
      </div>
    </section><!-- /Call To Action Section -->

    <!-- Product Section -->
    <section id="product" class="features section">
      <div class="container section-title" data-aos="fade-up">
        <h2>Product</h2>
      </div>
      <div class="container">
        <div class="row gy-4 align-items-center features-item">
          <div class="col-lg-5 order-2 order-lg-1" data-aos="fade-up" data-aos-delay="200">
            <dl>
              <dt>Title</dt>
              <dd>Next Generation</dd>
              <dt>Developer</dt>
              <dd>AstralSeal</dd>
              <dt>Genre</dt>
              <dd>Visual Novel / Dark Fantasy</dd>
              <dt>Status</dt>
              <dd>Coming Soon</dd>
            </dl>
            <div class="buttonrow">
              <a href="https://www.facebook.com/AstralSeal2023" class="btn btn-dark" target="_blank" rel="noopener noreferrer">
                <i class="bi bi-facebook"></i> Follow AstralSeal
              </a>
            </div>
          </div>
          <div class="col-lg-7 order-1 order-lg-2 d-flex align-items-center" data-aos="zoom-out" data-aos-delay="100">
            <div class="image-stack">
              <img src="/images/next/nex_logo.png" alt="Next Generation Logo" class="stack-front">
              <img src="/images/next/next1.png" alt="" class="stack-back">
            </div>
          </div>
        </div>
      </div>
    </section><!-- /Product Section -->

  </main>
</NextLayout>
