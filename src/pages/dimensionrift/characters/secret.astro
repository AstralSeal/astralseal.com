---
const character = {
  name: "???",
  cv: "Furorin",
  profileImage: "/images/dimensionrift/characters/secretcharacter_profile.png",
  detailImage: "/images/dimensionrift/characters/secretcharacter_detail.PNG",
  description: "A cat-eared young woman known as the \"Witch of Chaos.\" Wherever she goes, disaster and total ruin follow in her wake. Aside from the mayhem she leaves behind, no other information about her exists. At times, even she herself cannot remember her own past, making her a truly mysterious character."
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, maximum-scale=5.0, viewport-fit=cover"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
      integrity="sha512-iecdLmaskl7CVkqkXNQ/ZH/XLlvWZOJyj7Yy7tcenmpD1ypASozpmT/E0iPtmFIB46ZmdtAc9eNBvH0H/ZpiBw=="
      crossorigin="anonymous"
      referrerpolicy="no-referrer"
    />
    <title>??? - Dimension Rift Characters</title>
    <meta
      name="description"
      content={character.description}
    />
    <link href="/scripts/css/custom_dimensionrift.css" rel="stylesheet" />
  </head>
  <body>
    <!-- Top Bar -->
    <header class="topbar" role="banner">
      <div class="topbar-inner">
        <button
          class="mobile-menu-toggle"
          aria-label="Toggle menu"
          onclick="toggleMobileMenu(event)"
          aria-expanded="false"
          aria-controls="main-navigation"
        >
          <i class="fas fa-bars"></i>
        </button>
        <div class="nav-overlay" onclick="toggleMobileMenu()"></div>
        <a href="/dimensionrift" class="logo" aria-label="Back to Dimension Rift" style="padding: 4px 0;">
          <img
            src="/images/dimensionrift/logo_navbar.png"
            alt="Dimension Rift"
            style="height: 50px; width: auto; display: block;"
          />
        </a>
        <nav class="nav" id="main-navigation" aria-label="Primary">
          <a href="/dimensionrift">Back to Main</a>
          <a href="/dimensionrift#mainCharacters">All Characters</a>
        </nav>
      </div>
    </header>

    <!-- Main -->
    <main class="container">
      <div class="grid">
        <!-- Left Column -->
        <aside aria-label="Sidebar">
          <div class="card card-pad">
            <div class="cover" aria-label="Character profile">
              <img alt={character.name} src={character.profileImage} />
            </div>
            <div class="hr"></div>
            <h2 class="card-title">Character Info</h2>
            <table class="info-table">
              <tr><th>Name</th><td>{character.name}</td></tr>
              <tr><th>Voice Actor</th><td>{character.cv}</td></tr>
            </table>
            <div class="hr"></div>
            <a
              href="/dimensionrift#mainCharacters"
              class="btn"
              style="display: flex; align-items: center; justify-content: center; gap: 8px; text-decoration: none; width: 100%; background-color: #000; color: #fff; padding: 12px; font-weight: 600;"
            >
              <i class="fas fa-arrow-left" style="font-size: 1.2em;"></i>
              Back to Characters
            </a>
          </div>
        </aside>

        <!-- Right Column -->
        <section>
          <div class="card card-pad">
            <div class="titlebar">
              <div>
                <h1 class="title">{character.name}</h1>
                <p class="subtitle">CV: {character.cv}</p>
              </div>
            </div>

            <div class="hr"></div>

            <h2 class="card-title">Character Profile</h2>
            <div class="cover" aria-label="Character detail">
              <img
                src={character.detailImage}
                alt={character.name}
                style="height: auto; width: 100%; display: block;"
              />
            </div>
            <br />
            <p>{character.description}</p>
            <div class="hr"></div>
            <div class="vote-widget" data-vote-character="secret_character" style="margin-top: 12px; padding: 10px 12px; border: 1px solid var(--line, rgba(148, 163, 184, 0.4)); border-radius: 14px; display: flex; align-items: center; gap: 12px; background: rgba(241, 245, 249, 0.5);">
              <button type="button" class="vote-button" aria-label="Cheer for ???" style="width: 42px; height: 42px; border-radius: 50%; border: none; background: white; box-shadow: 0 4px 10px rgba(15, 23, 42, 0.12); color: var(--mal-blue, #2e51a2); display: flex; align-items: center; justify-content: center; cursor: pointer; transition: transform 0.15s ease, box-shadow 0.15s ease;">
                <i class="fas fa-thumbs-up"></i>
              </button>
              <div class="vote-stats" style="display: flex; flex-direction: column; line-height: 1.2;">
                <span class="vote-count" aria-live="polite" style="font-size: 1.1em; font-weight: 700; color: #0f172a;">0</span>
                <span class="vote-label" style="font-size: 0.8em; color: var(--muted, #64748b); text-transform: uppercase; letter-spacing: 0.08em;">Players cheered</span>
              </div>
            </div>
          </div>
        </section>
      </div>
    </main>

    <footer>
      <div class="footer-container">
        <p class="footer-copyright">© 2026 AstralSeal. All rights reserved.</p>
        <p class="footer-tagline">The Universe Belongs to the Seal!</p>
      </div>
    </footer>
    <script is:inline>
      const API_BASE = "/api/vote";

      // Fetch initial vote count
      fetch(`${API_BASE}/results`)
        .then((response) => response.json())
        .then((data) => {
          if (data.results && Array.isArray(data.results)) {
            data.results.forEach((character) => {
              const widget = document.querySelector(
                `.vote-widget[data-vote-character="${character.id}"]`,
              );
              if (widget) {
                const countElement = widget.querySelector(".vote-count");
                if (countElement) {
                  countElement.textContent = character.votes.toLocaleString();
                }
              }
            });
          }
        })
        .catch((error) => console.error("Error fetching votes:", error));

      // Handle vote button click
      const widget = document.querySelector(".vote-widget");
      if (widget) {
        const button = widget.querySelector(".vote-button");
        const countElement = widget.querySelector(".vote-count");
        const characterId = widget.getAttribute("data-vote-character");

        if (button && countElement && characterId) {
          button.addEventListener("click", function () {
            if (button.disabled) return;
            button.disabled = true;

            fetch(`${API_BASE}/vote`, {
              method: "POST",
              headers: {
                "Content-Type": "application/json",
              },
              body: JSON.stringify({ characterId: characterId }),
            })
              .then((response) => response.json())
              .then((data) => {
                if (data.success && data.character) {
                  countElement.textContent = data.character.votes.toLocaleString();
                  button.classList.add("voted");
                }
              })
              .catch((error) => console.error("Error submitting vote:", error))
              .finally(() => {
                setTimeout(function () {
                  button.classList.remove("voted");
                  button.disabled = false;
                }, 250);
              });
          });
        }
      }
    </script>
  </body>
</html>
