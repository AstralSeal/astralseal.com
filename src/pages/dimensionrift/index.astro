    <style>
      .vote-widget {
        margin-top: 12px;
        padding: 10px 12px;
        border: 1px solid var(--line, rgba(148, 163, 184, 0.4));
        border-radius: 14px;
        display: flex;
        align-items: center;
        gap: 12px;
        background: rgba(241, 245, 249, 0.5);
      }
      .vote-button {
        width: 42px;
        height: 42px;
        border-radius: 50%;
        border: none;
        background: white;
        box-shadow: 0 4px 10px rgba(15, 23, 42, 0.12);
        color: var(--mal-blue, #2e51a2);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition:
          transform 0.15s ease,
          box-shadow 0.15s ease;
      }
      .vote-button:hover {
        transform: translateY(-1px);
        box-shadow: 0 6px 14px rgba(15, 23, 42, 0.18);
      }
      .vote-button.voted {
        transform: scale(1.05);
      }
      .vote-stats {
        display: flex;
        flex-direction: column;
        line-height: 1.2;
      }
      .vote-count {
        font-size: 1.1em;
        font-weight: 700;
        color: #0f172a;
      }
      .vote-label {
        font-size: 0.8em;
        color: var(--muted, #64748b);
        text-transform: uppercase;
        letter-spacing: 0.08em;
      }
    </style>
