  <script is:inline>
    // Mobile menu toggle
    function toggleMobileMenu(event) {
      if (event) {
        event.stopPropagation();
        event.preventDefault();
      }

      const nav = document.querySelector(".nav");
      const toggleBtn = document.querySelector(".mobile-menu-toggle");
      const isOpen = nav.classList.contains("active");

      // Toggle menu state
      nav.classList.toggle("active");
      document.body.style.overflow = !isOpen ? "hidden" : "";

      // Update aria-expanded attribute
      toggleBtn.setAttribute("aria-expanded", !isOpen);

      // Change icon
      const icon = toggleBtn.querySelector("i");
      if (!isOpen) {
        icon.classList.remove("fa-bars");
        icon.classList.add("fa-times");
      } else {
        icon.classList.remove("fa-times");
        icon.classList.add("fa-bars");
      }
    }

    // Lightbox functions
    function openLightbox(src, caption = "") {
      const lightbox = document.getElementById("lightbox");
      const lightboxImg = document.getElementById("lightbox-img");
      const lightboxCaption = document.getElementById("lightbox-caption");

      if (lightbox && lightboxImg) {
        lightbox.style.display = "flex";
        lightboxImg.src = src;
        lightboxImg.alt = caption;

        if (lightboxCaption && caption) {
          lightboxCaption.textContent = caption;
          lightboxCaption.style.display = "block";
        } else if (lightboxCaption) {
          lightboxCaption.style.display = "none";
        }

        document.body.style.overflow = "hidden";
      }
    }

    function closeLightbox(event) {
      if (event) {
        event.stopPropagation();
      }

      const lightbox = document.getElementById("lightbox");
      if (lightbox) {
        lightbox.style.display = "none";
        document.body.style.overflow = "";
      }
    }

    // Close lightbox when clicking outside the image or on the close button
    document.addEventListener("DOMContentLoaded", function () {
      const lightbox = document.getElementById("lightbox");
      if (lightbox) {
        lightbox.addEventListener("click", function (event) {
          if (
            event.target === this ||
            event.target.classList.contains("close-btn")
          ) {
            closeLightbox(event);
          }
        });

        // Close with Escape key
        document.addEventListener("keydown", function (event) {
          if (event.key === "Escape" && lightbox.style.display === "flex") {
            closeLightbox(event);
          }
        });
      }
    });

    // Language Switcher
    document.addEventListener("DOMContentLoaded", function () {
      const languageButton = document.querySelector(".language-button");
      const languageDropdown = document.querySelector(".language-dropdown");
      const languageOptions = document.querySelectorAll(".language-option");

      if (!languageButton || !languageDropdown) return;

      // Toggle dropdown
      languageButton.addEventListener("click", function (e) {
        e.stopPropagation();
        const isOpen = languageDropdown.style.display === "block";
        languageDropdown.style.display = isOpen ? "none" : "block";
      });

      // Close dropdown when clicking outside
      document.addEventListener("click", function () {
        languageDropdown.style.display = "none";
      });

      // Prevent dropdown from closing when clicking inside it
      languageDropdown.addEventListener("click", function (e) {
        e.stopPropagation();
      });

      // Handle language selection
      languageOptions.forEach(function (option, index) {
        option.addEventListener("click", function (e) {
          e.preventDefault();
          e.stopPropagation();

          // Determine which language was selected (0 = English, 1 = Thai)
          const selectedLang = index === 0 ? "en" : "th";

          // Switch language using the external function
          if (typeof switchLanguage === "function") {
            switchLanguage(selectedLang);
          }

          // Close dropdown
          languageDropdown.style.display = "none";
        });
      });
    });

    document.addEventListener("DOMContentLoaded", function () {
      const API_BASE = "/api/vote";

      // Fetch initial vote counts
      fetch(`${API_BASE}/results`)
        .then((response) => response.json())
        .then((data) => {
          if (data.results && Array.isArray(data.results)) {
            data.results.forEach((character) => {
              const widget = document.querySelector(
                `.vote-widget[data-vote-character="${character.id}"]`,
              );
              if (widget) {
                const countElement = widget.querySelector(".vote-count");
                if (countElement) {
                  countElement.textContent = character.votes.toLocaleString();
                }
              }
            });
          }
        })
        .catch((error) => console.error("Error fetching votes:", error));

      const widgets = document.querySelectorAll(".vote-widget");
      widgets.forEach(function (widget) {
        const characterId = widget.getAttribute("data-vote-character");
        const button = widget.querySelector(".vote-button");
        const countElement = widget.querySelector(".vote-count");
        if (!characterId || !button || !countElement) {
          return;
        }

        button.addEventListener("click", function () {
          // Prevent double clicking
          if (button.disabled) return;
          button.disabled = true;

          fetch(`${API_BASE}/vote`, {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
            },
            body: JSON.stringify({ characterId: characterId }),
          })
            .then((response) => response.json())
            .then((data) => {
              if (data.success && data.character) {
                countElement.textContent =
                  data.character.votes.toLocaleString();
                button.classList.add("voted");
                // Optional: Trigger confetti or other effects here
              }
            })
            .catch((error) => console.error("Error submitting vote:", error))
            .finally(() => {
              setTimeout(function () {
                button.classList.remove("voted");
                button.disabled = false;
              }, 250);
            });
        });
      });
    });
    function scrollCarousel(dir) {
      const carousel = document.getElementById("charGrid");
      if (!carousel) return;

      const charElements = carousel.querySelectorAll(".char");
      if (charElements.length === 0) return;

      // Calculate scroll amount based on character width + gap
      const charWidth = charElements[0].offsetWidth;
      const gap = 16;
      const scrollAmount = charWidth + gap;

      carousel.scrollBy({ left: dir * scrollAmount, behavior: "smooth" });
    }
  </script>

